{
  "name": "stop-stack",
  "displayName": "Stop Stack",
  "description": "Stop local server processes from VS Code. Includes a kill-on-exit option. Works on Windows, macOS, and Linux. Detects many common local server frameworks and tools.",
  "version": "1.0.0",
  "publisher": "Protogenus",
  "repository": {
    "type": "git",
    "url": "https://github.com/Protogenus/stop-stack.git"
  },
  "homepage": "https://github.com/Protogenus/stop-stack",
  "bugs": {
    "url": "https://github.com/Protogenus/stop-stack/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "node",
    "process",
    "manager",
    "vscode",
    "extension",
    "stop",
    "stack",
    "local-server"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stopStack.showProcesses",
        "title": "Stop Stack: Open Dashboard"
      },
      {
        "command": "stopStack.killAll",
        "title": "Stop Stack: Kill All Local Servers"
      },
      {
        "command": "stopStack.refresh",
        "title": "Stop Stack: Refresh Dashboard",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Stop Stack",
      "properties": {
        "stopStack.killOnExit": {
          "type": "boolean",
          "default": true,
          "description": "Kill all local server processes when VS Code exits. On macOS, prompt first."
        },
        "stopStack.autoRefreshInterval": {
          "type": "number",
          "default": 5,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}