{
  "name": "kill-stack",
  "displayName": "Kill Stack",
  "description": "Stop local server processes from VS Code. Includes a kill-on-exit option. Works on Windows, macOS, and Linux. Detects many common local server frameworks, runtimes, and tunnels.",
  "version": "1.0.0",
  "publisher": "RedRiverDesign",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Protogenus/kill-stack.git"
  },
  "homepage": "https://github.com/Protogenus/kill-stack",
  "bugs": {
    "url": "https://github.com/Protogenus/kill-stack/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "vscode",
    "extension",
    "stop",
    "kill",
    "stack",
    "local-server",
    "process-manager",
    "dev-server",
    "local-dev",
    "tunnel"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "killStack.showProcesses",
        "title": "Kill Stack: Open Dashboard"
      },
      {
        "command": "killStack.killAll",
        "title": "Kill Stack: Kill All Local Servers"
      },
      {
        "command": "killStack.refresh",
        "title": "Kill Stack: Refresh Dashboard",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Kill Stack",
      "properties": {
        "killStack.killOnExit": {
          "type": "boolean",
          "default": false,
          "description": "Kill all local server processes when VS Code exits. On macOS, prompt first."
        },
        "killStack.autoRefreshInterval": {
          "type": "number",
          "default": 5,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
