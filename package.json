{
  "name": "node-process-manager",
  "displayName": "Node Process Manager",
  "description": "View and manage running Node.js processes from VS Code",
  "version": "1.0.0",
  "publisher": "Protogenus",
  "repository": {
    "type": "git",
    "url": "https://github.com/Protogenus/hush-node.git"
  },
  "homepage": "https://github.com/Protogenus/hush-node",
  "bugs": {
    "url": "https://github.com/Protogenus/hush-node/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "keywords": ["node", "process", "manager", "vscode", "extension"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nodeProcessManager.showProcesses",
        "title": "Node Process Manager: Show Running Node Processes"
      },
      {
        "command": "nodeProcessManager.killAll",
        "title": "Node Process Manager: Kill All Node Processes"
      },
      {
        "command": "nodeProcessManager.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "nodeProcessManager.killProcess",
        "title": "Kill Process",
        "icon": "$(trash)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "nodeProcesses",
          "name": "Node Processes"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "nodeProcessManager.refresh",
          "when": "view == nodeProcesses",
          "group": "navigation"
        },
        {
          "command": "nodeProcessManager.killAll",
          "when": "view == nodeProcesses",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "nodeProcessManager.killProcess",
          "when": "view == nodeProcesses && viewItem == nodeProcess",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Node Process Manager",
      "properties": {
        "nodeProcessManager.killOnExit": {
          "type": "boolean",
          "default": true,
          "description": "Kill all Node processes when VS Code exits. On supported platforms, prompt first."
        },
        "nodeProcessManager.autoRefreshInterval": {
          "type": "number",
          "default": 5,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
